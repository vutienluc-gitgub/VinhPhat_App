{
  "name": "vinhphat-app",
  "version": "1.0.0",
  "description": "Ứng dụng quản lý kho vải Vĩnh Phát",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "start": "open index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/js/",
    "lint:fix": "eslint src/js/ --fix",
    "format": "prettier --write \"src/**/*.{js,css}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,css}\" \"*.{json,md}\"",
    "check": "eslint src/js/ && prettier --check \"src/**/*.{js,css}\""
  },
  "keywords": [
    "vai",
    "kho",
    "quan-ly"
  ],
  "author": "VinhPhat",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jsdom": "^24.1.3",
    "prettier": "^3.8.1",
    "vitest": "^2.1.9"
  }
}
